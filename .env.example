# Agent 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ============================================
# LLM 配置（必填）- 支持阿里云百炼等 OpenAI 兼容接口
# ============================================

# API Key（必填，不填会导致启动失败）
# 阿里云百炼: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=

# 模型名称
# 阿里云百炼模型列表: https://help.aliyun.com/model-studio/getting-started/models
LLM_MODEL=qwen-plus

# API 基础 URL（可选，默认使用阿里云百炼）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1


# ============================================
# Agent 行为配置（可选）
# ============================================

# 最大工具执行轮次（防止无限循环）
AGENT_MAX_EXECUTIONS=10

# 工具执行超时时间（秒）
AGENT_TOOL_TIMEOUT_SECONDS=15

# 摘要最大字符数
AGENT_SUMMARY_MAX_CHARS=2000

# 是否允许沙箱网络访问
AGENT_ALLOW_NET=true


# ============================================
# 配置说明
# ============================================
# 1. 复制本文件: cp .env.example .env
# 2. 填写 ANTHROPIC_API_KEY
# 3. 按需调整其他配置
# 4. 运行: python -m agent "计算 1 到 100 的和"
